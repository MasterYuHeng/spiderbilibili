APP_NAME=spiderbilibili
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8014
APP_API_PREFIX=/api
APP_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Local development defaults.
# These values match docker-compose.yml.
DATABASE_URL=postgresql+psycopg://spider_user:spider_pass@127.0.0.1:5434/spider_bilibili
REDIS_URL=redis://127.0.0.1:6381/0
CELERY_BROKER_URL=redis://127.0.0.1:6381/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6381/2

# AI provider configuration.
# Recommended for first run:
# 1. Keep the defaults here
# 2. Configure the real API key in the frontend System Settings page
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_FALLBACK_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FALLBACK_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# Network and proxy.
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=3
PROXY_PROVIDER=
HTTP_PROXY=
HTTPS_PROXY=

# Bilibili login configuration.
# You can also configure this from the frontend System Settings page.
BILIBILI_COOKIE=
BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36

# Crawl runtime.
CRAWLER_MIN_SLEEP=1.5
CRAWLER_MAX_SLEEP=5
CRAWLER_MAX_PAGES=5
CRAWLER_MAX_VIDEOS=100
CRAWLER_CONCURRENCY=1
CRAWLER_ENABLE_PROXY=false
CRAWLER_RATE_LIMIT_PER_MINUTE=20
CRAWLER_SAVE_RAW_PAYLOADS=true
CRAWLER_RAW_DATA_DIR=./data/raw
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_SECONDS=30

# Pagination.
PAGINATION_DEFAULT_PAGE_SIZE=20
PAGINATION_MAX_PAGE_SIZE=100

# Logging.
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
