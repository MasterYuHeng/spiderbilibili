# Public entry
WEB_PORT=80
VITE_APP_TITLE=spiderbilibili
VITE_API_BASE_URL=
TZ=Asia/Shanghai

# Application
APP_NAME=spiderbilibili
APP_ENV=production
APP_DEBUG=false
APP_API_PREFIX=/api
APP_CORS_ORIGINS=https://your-domain.com

# Database
POSTGRES_DB=spider_bilibili
POSTGRES_USER=spider_user
POSTGRES_PASSWORD=change_me

# AI
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_FALLBACK_MODEL=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FALLBACK_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# Crawling
CRAWLER_MAX_PAGES=5
CRAWLER_MAX_VIDEOS=100
CRAWLER_MIN_SLEEP=1.5
CRAWLER_MAX_SLEEP=5
CRAWLER_RATE_LIMIT_PER_MINUTE=20
CRAWLER_ENABLE_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=
PLAYWRIGHT_HEADLESS=true

# Runtime
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
CELERY_LOG_LEVEL=info
CELERY_WORKER_CONCURRENCY=2
WORKER_GLOBAL_TASK_CONCURRENCY=2

# Monitoring
MONITORING_ENABLED=true
MONITORING_REDIS_PREFIX=spiderbilibili:monitoring
MONITORING_CELERY_QUEUE_NAME=celery
MONITORING_WORKER_HEARTBEAT_TTL_SECONDS=150
MONITORING_WORKER_EXPECTED_COUNT=1
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_ROOT_URL=http://your-domain.com:3000
APP_PUBLIC_BASE_URL=https://your-domain.com

# In-app alerting
ALERTING_ENABLED=false
ALERTING_DEDUPE_WINDOW_SECONDS=900
ALERTING_REQUEST_TIMEOUT_SECONDS=8
ALERTING_WECHAT_WEBHOOK=
ALERTING_DINGTALK_WEBHOOK=
ALERTING_EMAIL_ENABLED=false
ALERTING_EMAIL_SMTP_HOST=
ALERTING_EMAIL_SMTP_PORT=587
ALERTING_EMAIL_USERNAME=
ALERTING_EMAIL_PASSWORD=
ALERTING_EMAIL_FROM=
ALERTING_EMAIL_TO=
ALERTING_EMAIL_USE_TLS=true
